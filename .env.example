# Copy this file to .env and adjust. The binary loads .env from the current
# working directory on startup (missing file is OK). Do not commit .env.
#
# The sample password value ends with _EXAMPLE to mark it as a placeholder;
# replace it with a real secret for non-local use.
#
# Used when provisioning DB + app tiers via Podman or the k8s container SP
# (POSTGRES_*/MYSQL_* and Spring SPRING_DATASOURCE_*).

TIER_STACK_DB_PASSWORD=petclinic_EXAMPLE
TIER_STACK_DB_NAME=petclinic
TIER_STACK_POSTGRES_USER=postgres
TIER_STACK_MYSQL_USER=root

# --- k8s container SP (leave unset for mock / Podman) ---
# CONTAINER_SP_URL=http://localhost:9081

# Web tier: kubernetes (default) uses external Service + LoadBalancer IP when
# available; openshift creates an OpenShift Route to <name>-web (needs kube API).
# SP_WEB_EXPOSURE=kubernetes

# Required when SP_WEB_EXPOSURE=openshift (same namespace as k8s container SP):
# SP_OPENSHIFT_ROUTE_NAMESPACE=default

# Optional kubeconfig for Route create/delete (else KUBECONFIG / ~/.kube/config):
# SP_OPENSHIFT_KUBECONFIG=
